    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "patchedDependencies": {
      "@astrojs/sitemap@3.7.2": "patches/@astrojs__sitemap@3.7.2.patch"
    }
  }
